# ============================================================
# .env.example  ->  bu dosyayı `.env` olarak kopyala ve doldur
# ============================================================
# Kullanım:
#   cp .env.example .env
#   # sonra aşağıdaki değerleri kendi token / kullanıcı adınla değiştir
#
# UYARI:
#   - .env dosyası .gitignore içindedir, repo'ya COMMIT EDİLMEZ.
#   - Buradaki "demo-1234" değeri sadece bu örnek için anlamlıdır;
#     gerçek bir API key değildir.
# ============================================================

# Demo "API anahtarı". Sunucudaki `kimligimi_dogrula` tool'u bunu okur.
# Doğru çalıştığını görmek için aşağıdaki değeri "demo-1234" yap.
DEMO_API_KEY=demo-1234

# İsteğe bağlı kullanıcı adı (loglarda / cevaplarda görünür).
DEMO_USER=alperen

# Gerçek hayatta API endpoint'i için kullanırsın; bu örnekte sadece
# env://status resource'unda "tanımlı/tanımsız" olarak listelenir.
DEMO_BASE_URL=https://api.example.com
